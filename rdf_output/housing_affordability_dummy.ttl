@prefix lh: <https://example.org/leipzig-housing/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/leipzig-housing/affordability_observation/connewitz_students_bafog_only> a lh:AffordabilityObservation ;
    lh:forDistrict <https://example.org/leipzig-housing/district/connewitz> ;
    lh:forGroup <https://example.org/leipzig-housing/group/students> ;
    lh:forIncomeScenario <https://example.org/leipzig-housing/income_scenario/bafog_only> ;
    lh:hasAffordabilityStatus "critical"@en ;
    lh:hasHousingStressScore 0.442 ;
    lh:hasMonthlyIncome 992.0 ;
    lh:hasWarmRent 438.6 .

